# Kopieer naar .env en vul je echte sleutel in. NOOIT .env committen.
# Haal een key bij https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optioneel — getoond in OpenRouter-dashboard als herkomst van je calls.
OPENROUTER_APP_TITLE=DreamTeam-Benchmark
OPENROUTER_APP_URL=https://lexxy.local

# --- 3-armen Fugu-benchmark (src/arms3) ---
# Eén sandbox-OpenRouter-key ontgrendelt alle drie de armen.
# Arm B (sakana/fugu-ultra via OpenRouter): valt terug op OPENROUTER_API_KEY als FUGU_API_KEY leeg is.
# FUGU_API_KEY=sk-or-...            # mag dezelfde OpenRouter-key zijn
# Arm C (lokale OpenFugu op :8088): harness-key is een dummy (lokale server negeert auth).
# FUGU_LOCAL_KEY=local-dummy
# De OpenFugu-server zelf belt zijn worker-pool via OpenRouter; zet bij het starten van serve.py:
#   FUGU_BASE_URL=https://openrouter.ai/api/v1  FUGU_API_KEY=$OPENROUTER_API_KEY

# Optioneel (dispatch fase 2) — pad naar models-routing.json. Leeg = vault-default.
# MODEL_ROUTING_PATH=/Users/lex/Library/Mobile Documents/com~apple~CloudDocs/LXY-Vault/00-System/skills/model-router/models-routing.json

# Verplicht voor `npm run serve` (dispatch fase 3 DEEL B, HTTP-endpoint richting n8n).
# Gedeeld geheim: n8n's HTTP Request-node moet dit meesturen als header x-dispatch-token.
# Genereer bv. met: openssl rand -hex 24 . Endpoint start NIET zonder dit geheim.
# DISPATCH_HTTP_TOKEN=
# DISPATCH_HTTP_PORT=8787
