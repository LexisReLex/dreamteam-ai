# Anthropic API Key - vereist voor AI-agents
ANTHROPIC_API_KEY=sk-ant-...

# Server poort (Railway zet dit automatisch)
PORT=5000

# Node omgeving
NODE_ENV=production

# Dagelijks token-limiet (optioneel, standaard 100000)
DAILY_TOKEN_LIMIT=100000

# Groq als gratis LLM-pad (optioneel). Zonder GROQ_API_KEY draait alles op Claude
# en verandert er niets. Met een key routeert de model-router support-/algemeen-
# werk naar Groq (gratis, snel); faalt Groq, dan valt het antwoord terug op Claude.
# Gratis key aanmaken: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Pad naar de SQLite-database (optioneel, standaard "data.db").
# Zet dit op een gemount persistent volume zodat loops, runs en state een
# redeploy overleven. Op Railway: mount een Volume op /data en gebruik:
# DB_PATH=/data/dreamteam.db

# Toegangsbescherming voor de dure endpoints (optioneel, standaard uit).
# Geen volwaardige gebruikers-auth — defense-in-depth tegen drive-by misbruik.
# ALLOWED_ORIGINS: komma-gescheiden lijst; cross-site browser-calls van andere
# origins worden geweigerd. Bv. ALLOWED_ORIGINS=https://jouwdomein.nl
# API_ACCESS_TOKEN: alleen voor afgeschermde/interne deploys (geen publieke SPA);
# vereist dan de header x-api-token op /api/messages en /api/loops/:id/run.
# ALLOWED_ORIGINS=
# API_ACCESS_TOKEN=
